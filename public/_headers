# Cloudflare Pages — Cache-Control 정책
#
# Lighthouse "efficient cache policy" 통과를 위해 자산별 적정 TTL 부여.
# 정적 export(output: "export") 환경이라 next.config.js headers는 무효 → _headers 사용.

# Next.js 정적 청크 — 파일명에 해시 박힘, 1년 immutable 안전
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# 자체 이미지 — 30일 캐시 + 재검증
/images/*
  Cache-Control: public, max-age=2592000, must-revalidate

# OG 이미지 — 30일
/og-image.webp
  Cache-Control: public, max-age=2592000, must-revalidate

# 파비콘 — 30일
/icon.svg
  Cache-Control: public, max-age=2592000, must-revalidate

# 사이트맵·robots — 1일 (검색엔진 재크롤링 주기 고려)
/sitemap.xml
  Cache-Control: public, max-age=86400, must-revalidate
/robots.txt
  Cache-Control: public, max-age=86400, must-revalidate

# HTML — 짧게 (콘텐츠 변경 즉시 반영) + Cloudflare CDN 자동 캐싱은 유지
/*.html
  Cache-Control: public, max-age=600, must-revalidate

# 보안 헤더 (전체 경로)
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
